generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 💳 SUBSCRIPTION PLANS (configurable pricing tiers)
// ============================================================
model SubscriptionPlan {
  id              String   @id @default(cuid())
  code            String   @unique                    // starter, pro, enterprise
  name            String                               // Starter, Pro, Enterprise
  priceMonthly    Float                                // in XOF (FCFA)
  currency        String   @default("XOF")
  maxEvents       Int      @default(5)
  maxTicketsPerEvent Int   @default(500)
  maxUsers        Int      @default(3)
  maxTicketsMonth Int      @default(0)                 // 0 = unlimited
  features        String   @default("[]")              // JSON string array
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]

  @@index([code])
  @@index([isActive])
}

// ============================================================
// 📋 SUBSCRIPTIONS (org subscription lifecycle)
// ============================================================
model Subscription {
  id              String   @id @default(cuid())
  organizationId  String
  planCode        String                               // references SubscriptionPlan.code
  amount          Float
  currency        String   @default("XOF")
  startDate       DateTime
  endDate         DateTime
  status          String   @default("pending")          // pending, active, expired, cancelled
  paymentMethod   String   @default("wave")             // wave, orange_money, stripe, manual
  externalRef     String?                              // ID transaction Wave/OM (idempotence)
  webhookPayload  String?                              // JSON string (raw webhook payload)
  metadata        String   @default("{}")               // JSON string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan @relation(fields: [planCode], references: [code])

  @@unique([externalRef])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([endDate])
  @@index([paymentMethod])
}

// ============================================================
// 🏢 MULTI-TENANT: Organization (SaaS tenant)
// ============================================================
model Organization {
  id                   String          @id @default(cuid())
  uuid                 String          @unique
  name                 String
  slug                 String          @unique
  logoUrl              String?
  primaryColor         String          @default("#059669")
  phone                String?
  email                String?
  subscriptionPlan     String          @default("starter")
  subscriptionStatus   String          @default("trial")
  subscriptionExpiresAt DateTime?
  maxEvents            Int             @default(5)
  maxTicketsPerEvent   Int             @default(500)
  maxUsers             Int             @default(3)
  settings             String          @default("{}")
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  users         User[]
  events        Event[]
  scans         Scan[]
  transactions  Transaction[]
  activityLogs  ActivityLog[]
  subscriptions Subscription[]
  orgSecret     OrgSecret?
  scanLogs      ScanLog[]
  offlineQueue  OfflineScanQueue[]

  @@index([slug])
  @@index([subscriptionStatus])
  @@index([isActive])
}

// ============================================================
// 👤 Users (multi-tenant: belongs to Organization)
// ============================================================
model User {
  id              String   @id @default(cuid())
  email           String
  name            String
  password        String
  role            String   @default("operator")
  avatar          String?
  isActive        Boolean  @default(true)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events        Event[]
  tickets       Ticket[]
  scans         Scan[]
  activityLogs  ActivityLog[]
  transactions  Transaction[]

  @@unique([email, organizationId])
  @@index([role])
  @@index([email])
  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, isActive])
}

// ============================================================
// 🎟️ Events (multi-tenant: scoped to Organization)
// ============================================================
model Event {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("event")
  description    String?
  location       String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime
  endDate        DateTime
  totalTickets   Int      @default(100)
  soldTickets    Int      @default(0)
  price          Float
  currency       String   @default("USD")
  status         String   @default("active")
  image          String?
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  tickets       Ticket[]
  scans         Scan[]
  transactions  Transaction[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

// ============================================================
// 🎫 Tickets
// ============================================================
model Ticket {
  id            String    @id @default(cuid())
  eventId       String
  userId        String?
  ticketCode    String    @unique
  ticketType    String    @default("Standard")
  holderName    String
  holderEmail   String
  holderPhone   String?
  seatNumber    String?
  price         Float
  currency      String    @default("USD")
  status        String    @default("active")
  validatedAt   DateTime?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  event        Event         @relation(fields: [eventId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  scans        Scan[]
  transactions Transaction[]

  @@index([eventId])
  @@index([ticketCode])
  @@index([status])
  @@index([holderEmail])
}

// ============================================================
// 📲 Scans
// ============================================================
model Scan {
  id             String   @id @default(cuid())
  ticketId       String
  eventId        String
  scannedBy      String
  organizationId String
  result         String   @default("valid")
  deviceInfo     String?
  location       String?
  latitude       Float?
  longitude      Float?
  geoAlert       Boolean  @default(false)
  isSynced       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket        Ticket       @relation(fields: [ticketId], references: [id])
  event         Event        @relation(fields: [eventId], references: [id])
  user          User         @relation(fields: [scannedBy], references: [id])

  @@index([ticketId])
  @@index([eventId])
  @@index([scannedBy])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

// ============================================================
// 💰 Transactions
// ============================================================
model Transaction {
  id             String   @id @default(cuid())
  eventId        String?
  ticketId       String?
  userId         String?
  organizationId String
  amount         Float
  currency       String   @default("USD")
  status         String   @default("completed")
  paymentMethod  String   @default("cash")
  reference      String?
  description    String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event         Event?       @relation(fields: [eventId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([ticketId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

// ============================================================
// 🔑 ORG SECRETS (HMAC key per org for QR signing)
// ============================================================
model OrgSecret {
  id             String   @id @default(cuid())
  organizationId String   @unique
  hmacSecret     String
  previousSecret String?
  rotatedAt      DateTime?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ============================================================
// 📲 SCAN LOGS (audit trail with geo + device data)
// ============================================================
model ScanLog {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  eventId        String
  operatorId     String
  scannedAt      DateTime @default(now())
  status         String                                    // valid, used, expired, invalid
  latitude       Float?
  longitude      Float?
  deviceUA       String?
  isSynced       Boolean  @default(true)
  geoAlert       Boolean  @default(false)
  geoDistance    Float?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, ticketId])
  @@index([organizationId, scannedAt])
  @@index([operatorId])
  @@index([status])
}

// ============================================================
// 📴 OFFLINE SCAN QUEUE (pending sync from PWA)
// ============================================================
model OfflineScanQueue {
  id             String   @id @default(cuid())
  organizationId String
  ticketHash     String
  operatorId     String?
  scannedAt      DateTime @default(now())
  latitude       Float?
  longitude      Float?
  syncStatus     String   @default("pending")     // pending, synced, failed
  retryCount     Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  syncedAt       DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([syncStatus])
  @@index([organizationId, syncStatus])
  @@index([createdAt])
}

// ============================================================
// 📋 Activity Logs
// ============================================================
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  details        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
}
