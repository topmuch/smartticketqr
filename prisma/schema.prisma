generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 🏢 MULTI-TENANT: Organization (SaaS tenant)
// ============================================================
model Organization {
  id                   String   @id @default(cuid())
  uuid                 String   @unique
  name                 String
  slug                 String   @unique
  logoUrl              String?
  primaryColor         String   @default("#059669")
  phone                String?
  email                String?
  subscriptionPlan     String   @default("starter")     // starter, pro, enterprise
  subscriptionStatus   String   @default("trial")       // trial, active, expired, cancelled
  subscriptionExpiresAt DateTime?
  maxEvents            Int      @default(5)
  maxTicketsPerEvent   Int      @default(500)
  maxUsers             Int      @default(3)
  settings             String   @default("{}")           // JSON string (SQLite has no native JSON)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  users         User[]
  events        Event[]
  scans         Scan[]
  transactions  Transaction[]
  activityLogs  ActivityLog[]

  @@index([slug])
  @@index([subscriptionStatus])
  @@index([isActive])
}

// ============================================================
// 👤 Users (multi-tenant: belongs to Organization)
// ============================================================
model User {
  id              String   @id @default(cuid())
  email           String
  name            String
  password        String
  role            String   @default("operator")   // super_admin, admin, operator
  avatar          String?
  isActive        Boolean  @default(true)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events        Event[]
  tickets       Ticket[]
  scans         Scan[]
  activityLogs  ActivityLog[]
  transactions  Transaction[]

  @@unique([email, organizationId])   // same email can exist in different orgs
  @@index([role])
  @@index([email])
  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, isActive])
}

// ============================================================
// 🎟️ Events (multi-tenant: scoped to Organization)
// ============================================================
model Event {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("event")       // event, bus, boat, ferry
  description    String?
  location       String?
  startDate      DateTime
  endDate        DateTime
  totalTickets   Int      @default(100)
  soldTickets    Int      @default(0)
  price          Float
  currency       String   @default("USD")
  status         String   @default("active")       // active, paused, completed, cancelled
  image          String?
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  tickets       Ticket[]
  scans         Scan[]
  transactions  Transaction[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

// ============================================================
// 🎫 Tickets (multi-tenant: scoped via Event → Organization)
// ============================================================
model Ticket {
  id            String    @id @default(cuid())
  eventId       String
  userId        String?
  ticketCode    String    @unique
  ticketType    String    @default("Standard")     // VIP, Standard, One-way, Round-trip
  holderName    String
  holderEmail   String
  holderPhone   String?
  seatNumber    String?
  price         Float
  currency      String    @default("USD")
  status        String    @default("active")       // active, used, expired, cancelled
  validatedAt   DateTime?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  event        Event         @relation(fields: [eventId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  scans        Scan[]
  transactions Transaction[]

  @@index([eventId])
  @@index([ticketCode])
  @@index([status])
  @@index([holderEmail])
}

// ============================================================
// 📲 Scans (multi-tenant: scoped to Organization)
// ============================================================
model Scan {
  id             String   @id @default(cuid())
  ticketId       String
  eventId        String
  scannedBy      String
  organizationId String
  result         String   @default("valid")        // valid, invalid, already_used, expired
  deviceInfo     String?
  location       String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket        Ticket       @relation(fields: [ticketId], references: [id])
  event         Event        @relation(fields: [eventId], references: [id])
  user          User         @relation(fields: [scannedBy], references: [id])

  @@index([ticketId])
  @@index([eventId])
  @@index([scannedBy])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

// ============================================================
// 💰 Transactions (multi-tenant: scoped to Organization)
// ============================================================
model Transaction {
  id             String   @id @default(cuid())
  eventId        String?
  ticketId       String?
  userId         String?
  organizationId String
  amount         Float
  currency       String   @default("USD")
  status         String   @default("completed")    // pending, completed, failed, refunded
  paymentMethod  String   @default("cash")          // stripe, wave, orange_money, cash, free
  reference      String?
  description    String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event         Event?       @relation(fields: [eventId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([ticketId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

// ============================================================
// 📋 Activity Logs (multi-tenant: scoped to Organization)
// ============================================================
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  details        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
}
