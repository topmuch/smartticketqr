generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// 💳 SUBSCRIPTION PLANS (configurable pricing tiers)
// ============================================================
model SubscriptionPlan {
  id              String   @id @default(cuid())
  code            String   @unique                    // starter, pro, enterprise
  name            String                               // Starter, Pro, Enterprise
  priceMonthly    Float                                // in XOF (FCFA)
  currency        String   @default("XOF")
  maxEvents       Int      @default(5)
  maxTicketsPerEvent Int   @default(500)
  maxUsers        Int      @default(3)
  maxTicketsMonth Int      @default(0)                 // 0 = unlimited
  features        String   @default("[]")              // JSON string array
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  subscriptions   Subscription[]

  @@index([code])
  @@index([isActive])
}

// ============================================================
// 📋 SUBSCRIPTIONS (org subscription lifecycle)
// ============================================================
model Subscription {
  id              String   @id @default(cuid())
  organizationId  String
  planCode        String                               // references SubscriptionPlan.code
  amount          Float
  currency        String   @default("XOF")
  startDate       DateTime
  endDate         DateTime
  status          String   @default("pending")          // pending, active, expired, cancelled
  paymentMethod   String   @default("wave")             // wave, orange_money, stripe, manual
  externalRef     String?                              // ID transaction Wave/OM (idempotence)
  webhookPayload  String?                              // JSON string (raw webhook payload)
  metadata        String   @default("{}")               // JSON string
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan            SubscriptionPlan @relation(fields: [planCode], references: [code])

  @@unique([externalRef])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([status])
  @@index([endDate])
  @@index([paymentMethod])
}

// ============================================================
// 🏢 MULTI-TENANT: Organization (SaaS tenant)
// ============================================================
model Organization {
  id                   String          @id @default(cuid())
  uuid                 String          @unique
  name                 String
  slug                 String          @unique
  logoUrl              String?
  primaryColor         String          @default("#059669")
  phone                String?
  email                String?
  subscriptionPlan     String          @default("starter")
  subscriptionStatus   String          @default("trial")
  subscriptionExpiresAt DateTime?
  maxEvents            Int             @default(5)
  maxTicketsPerEvent   Int             @default(500)
  maxUsers             Int             @default(3)
  settings             String          @default("{}")
  isActive             Boolean         @default(true)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  users         User[]
  events        Event[]
  scans         Scan[]
  transactions  Transaction[]
  activityLogs  ActivityLog[]
  subscriptions Subscription[]
  orgSecret     OrgSecret?
  scanLogs      ScanLog[]
  offlineQueue  OfflineScanQueue[]
  statsCache    OrgStatsCache?
  auditLogs     AuditLog[]
  apiKeys           ApiKey[]
  webhookEndpoints  WebhookEndpoint[]
  webhookLogs       WebhookLog[]
  customDomains     CustomDomain[]
  automationRules   AutomationRule[]
  supportTickets    SupportTicket[]
  affiliates        Affiliate[]
  fraudAlerts       FraudAlert[]
  transportLines    TransportLine[]
  fareTypes         FareType[]
  ticketExtras      TicketExtra[]
  promoCodes        PromoCode[]

  @@index([slug])
  @@index([subscriptionStatus])
  @@index([isActive])
}

// ============================================================
// 🏷️ FARE TYPES (Social pricing tiers: child, student, senior, etc.)
// ============================================================
model FareType {
  id              String   @id @default(cuid())
  organizationId  String
  slug            String                               // 'standard', 'child', 'student', 'senior', 'group', 'round_trip'
  name            String                               // "Enfant", "Étudiant", "Senior"
  emoji           String   @default("🎫")
  priceModifier   Float    @default(1.00)                 // 0.50 = -50%, 2.00 = x2 (aller-retour)
  requiresProof   Boolean  @default(false)                // Carte étudiant, pièce identité
  proofLabel      String   @default("")                    // "Carte étudiant", "PIèce identité"
  ageMin          Int?                                     // Enfant: 0-12, Senior: 60+
  ageMax          Int?
  maxPerBooking   Int      @default(10)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tickets         Ticket[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isActive])
}

// ============================================================
// 🧳 TICKET EXTRAS (Bagage, Vélo, Animal, Voiture)
// ============================================================
model TicketExtra {
  id              String   @id @default(cuid())
  organizationId  String
  slug            String                               // 'bagage_sup', 'velo', 'animal', 'voiture'
  name            String                               // "Bagage supplémentaire", "Vélo/Moto"
  emoji           String   @default("📦")
  pricingType      String   @default("fixed")                // fixed, per_unit, per_kg
  basePrice       Float                                   // Prix unitaire en FCFA
  requiresDetails  Boolean  @default(false)                // ex: plaque immatriculation
  detailLabel      String   @default("")                    // "Plaque d'immatriculation", "Poids en kg"
  maxPerTicket    Int      @default(5)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  ticketItems    TicketItem[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([isActive])
}

// ============================================================
// 🔗 TICKET ITEMS (Junction: Ticket ↔ Extras)
// ============================================================
model TicketItem {
  id              String   @id @default(cuid())
  ticketId        String
  extraId         String
  quantity        Int      @default(1)
  unitPrice       Float
  details         String   @default("")                    // JSON: {"plate":"DK-1234-AB", "weight_kg":15}
  createdAt       DateTime @default(now())

  ticket          Ticket     @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  extra           TicketExtra @relation(fields: [extraId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([extraId])
}

// ============================================================
// 🏷️ PROMO CODES (Discount codes)
// ============================================================
model PromoCode {
  id              String   @id @default(cuid())
  organizationId  String
  code            String                               // "NOEL2026", "GROUPE10"
  type            String   @default("percent")              // percent, fixed
  value           Float                                   // 10 = 10%, 500 = 500 FCFA
  minTickets      Int      @default(1)
  validFrom       DateTime?
  validUntil      DateTime?
  maxUses         Int?
  usedCount        Int      @default(0)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tickets         Ticket[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, code])
  @@index([organizationId])
  @@index([isActive])
}

// ============================================================
// 👤 Users (multi-tenant: belongs to Organization)
// ============================================================
model User {
  id              String   @id @default(cuid())
  email           String
  name            String
  password        String
  role            String   @default("operator")
  avatar          String?
  isActive        Boolean  @default(true)
  organizationId  String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events        Event[]
  tickets       Ticket[]
  scans         Scan[]
  activityLogs  ActivityLog[]
  transactions  Transaction[]
  auditLogs      AuditLog[]
  supportTickets SupportTicket[]

  @@unique([email, organizationId])
  @@index([role])
  @@index([email])
  @@index([organizationId])
  @@index([organizationId, role])
  @@index([organizationId, isActive])
}

// ============================================================
// 🎟️ Events (multi-tenant: scoped to Organization)
// ============================================================
model Event {
  id             String   @id @default(cuid())
  name           String
  type           String   @default("event")
  description    String?
  location       String?
  latitude       Float?
  longitude      Float?
  startDate      DateTime
  endDate        DateTime
  totalTickets   Int      @default(100)
  soldTickets    Int      @default(0)
  price          Float
  currency       String   @default("USD")
  status         String   @default("active")
  image          String?
  userId         String
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization  Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id])
  tickets       Ticket[]
  scans         Scan[]
  transactions  Transaction[]

  @@index([type])
  @@index([status])
  @@index([userId])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, type])
  @@index([organizationId, createdAt])
}

// ============================================================
// 🎫 Tickets
// ============================================================
model Ticket {
  id            String    @id @default(cuid())
  eventId       String
  userId        String?
  ticketCode    String    @unique
  ticketType    String    @default("Standard")
  holderName    String
  holderEmail   String
  holderPhone   String?
  seatNumber    String?
  price         Float
  currency      String    @default("USD")
  status        String    @default("active")
  validatedAt   DateTime?
  issuedAt      DateTime  @default(now())
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  fareTypeId    String?                                  // Fare type (student, child, senior, etc.)
  promoCodeId   String?                                  // Applied promo code
  basePrice     Float                                   // Original price before modifiers
  extrasTotal   Float    @default(0)                     // Sum of extras
  discountAmount Float    @default(0)                     // Promo discount

  event        Event         @relation(fields: [eventId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])
  fareType     FareType?     @relation(fields: [fareTypeId], references: [id])
  promoCode    PromoCode?    @relation(fields: [promoCodeId], references: [id])
  ticketItems  TicketItem[]
  scans        Scan[]
  transactions Transaction[]

  @@index([eventId])
  @@index([ticketCode])
  @@index([status])
  @@index([holderEmail])
  @@index([fareTypeId])
  @@index([promoCodeId])
}

// ============================================================
// 📲 Scans
// ============================================================
model Scan {
  id             String   @id @default(cuid())
  ticketId       String
  eventId        String
  scannedBy      String
  organizationId String
  result         String   @default("valid")
  deviceInfo     String?
  location       String?
  latitude       Float?
  longitude      Float?
  geoAlert       Boolean  @default(false)
  isSynced       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  ticket        Ticket       @relation(fields: [ticketId], references: [id])
  event         Event        @relation(fields: [eventId], references: [id])
  user          User         @relation(fields: [scannedBy], references: [id])

  @@index([ticketId])
  @@index([eventId])
  @@index([scannedBy])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, createdAt])
}

// ============================================================
// 💰 Transactions
// ============================================================
model Transaction {
  id             String   @id @default(cuid())
  eventId        String?
  ticketId       String?
  userId         String?
  organizationId String
  amount         Float
  currency       String   @default("USD")
  status         String   @default("completed")
  paymentMethod  String   @default("cash")
  reference      String?
  description    String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event         Event?       @relation(fields: [eventId], references: [id])
  ticket        Ticket?      @relation(fields: [ticketId], references: [id])
  user          User?        @relation(fields: [userId], references: [id])

  @@index([eventId])
  @@index([ticketId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, createdAt])
}

// ============================================================
// 🔑 ORG SECRETS (HMAC key per org for QR signing)
// ============================================================
model OrgSecret {
  id             String   @id @default(cuid())
  organizationId String   @unique
  hmacSecret     String
  previousSecret String?
  rotatedAt      DateTime?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

// ============================================================
// 📲 SCAN LOGS (audit trail with geo + device data)
// ============================================================
model ScanLog {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String
  eventId        String
  operatorId     String
  scannedAt      DateTime @default(now())
  status         String                                    // valid, used, expired, invalid
  latitude       Float?
  longitude      Float?
  deviceUA       String?
  isSynced       Boolean  @default(true)
  geoAlert       Boolean  @default(false)
  geoDistance    Float?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, ticketId])
  @@index([organizationId, scannedAt])
  @@index([operatorId])
  @@index([status])
}

// ============================================================
// 📴 OFFLINE SCAN QUEUE (pending sync from PWA)
// ============================================================
model OfflineScanQueue {
  id             String   @id @default(cuid())
  organizationId String
  ticketHash     String
  operatorId     String?
  scannedAt      DateTime @default(now())
  latitude       Float?
  longitude      Float?
  syncStatus     String   @default("pending")     // pending, synced, failed
  retryCount     Int      @default(0)
  errorMessage   String?
  createdAt      DateTime @default(now())
  syncedAt       DateTime?

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([syncStatus])
  @@index([organizationId, syncStatus])
  @@index([createdAt])
}

// ============================================================
// 📋 Activity Logs
// ============================================================
model ActivityLog {
  id             String   @id @default(cuid())
  userId         String?
  organizationId String
  action         String
  details        String?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization  Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          User?        @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([organizationId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
}

// ============================================================
// 📊 ORG STATS CACHE (materialized view for performance)
// ============================================================
model OrgStatsCache {
  id                  String   @id @default(cuid())
  organizationId      String   @unique
  totalRevenueMonth   Float    @default(0)
  totalTicketsSoldMonth Int    @default(0)
  totalScansToday     Int      @default(0)
  totalScansWeek      Int      @default(0)
  totalTicketsAll     Int      @default(0)
  totalActiveEvents   Int      @default(0)
  validationRate      Float    @default(0)
  lastUpdated         DateTime @default(now())

  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([lastUpdated])
}

// ============================================================
// 🔐 AUDIT LOGS (security trail for sensitive actions)
// ============================================================
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  action         String                                   // LOGIN_FAIL, PRICE_CHANGE, TICKET_DELETE, EVENT_UPDATE, USER_DEACTIVATE, PERMISSION_CHANGE
  targetType     String?                                  // event, ticket, user, subscription
  targetId       String?
  details        String?                                  // JSON string with old/new values
  ipAddress      String?
  userAgent      String?
  severity       String   @default("info")                // info, warning, critical
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, action])
  @@index([organizationId, createdAt])
  @@index([userId])
  @@index([action])
  @@index([severity])
  @@index([createdAt])
}

// ============================================================
// 🔑 API KEYS (per-organization API access)
// ============================================================
model ApiKey {
  id             String    @id @default(cuid())
  organizationId String
  keyHash        String    @unique                         // SHA-256 hash of the raw key
  keyPrefix      String                                    // First 8 chars for display
  name           String                                    // e.g. "Mobile App", "Partner Integration"
  permissions    String    @default("[\"read\"]")           // JSON: ["read","write"]
  rateLimit      Int       @default(100)                   // Requests per hour
  lastUsedAt     DateTime?
  isActive       Boolean   @default(true)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([keyPrefix])
}

// ============================================================
// 🪝 WEBHOOK ENDPOINTS (outbound webhook configs per org)
// ============================================================
model WebhookEndpoint {
  id             String   @id @default(cuid())
  organizationId String
  url            String                                   // HTTPS endpoint URL
  events         String                                   // JSON: ["ticket.validated","subscription.expired"]
  secret         String                                   // HMAC signing secret
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  logs           WebhookLog[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

// ============================================================
// 📨 WEBHOOK LOGS (delivery tracking + retry state)
// ============================================================
model WebhookLog {
  id             String    @id @default(cuid())
  organizationId String
  endpointId     String
  eventType      String                                    // ticket.created, ticket.validated, etc.
  payload        String?                                   // JSON string
  httpStatus     Int?
  responseBody   String?
  attempts       Int       @default(1)
  nextRetryAt    DateTime?
  status         String    @default("pending")              // pending, delivered, failed
  createdAt      DateTime  @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  endpoint       WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([endpointId])
  @@index([status])
  @@index([status, nextRetryAt])
  @@index([eventType])
  @@index([createdAt])
}

// ============================================================
// 🌐 CUSTOM DOMAINS (white-label per-organization)
// ============================================================
model CustomDomain {
  id             String   @id @default(cuid())
  organizationId String   @unique
  domain         String   @unique                           // e.g. billetterie.maboite.sn
  sslStatus      String   @default("pending")               // pending, active, failed
  isActive       Boolean  @default(true)
  faviconUrl     String?                                    // custom favicon
  emailFrom      String?                                    // custom sender email
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([domain])
  @@index([sslStatus])
}

// ============================================================
// 🌍 TRANSLATIONS (i18n key-value store)
// ============================================================
model Translation {
  id            String   @id @default(cuid())
  langCode      String                                     // fr, en, wo, etc.
  translationKey String                                   // dashboard.stats.revenue
  text          String                                    // translated text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([langCode, translationKey])
  @@index([langCode])
  @@index([translationKey])
}

// ============================================================
// ⚙️ AUTOMATION RULES (notification sequences per org)
// ============================================================
model AutomationRule {
  id             String   @id @default(cuid())
  organizationId String
  triggerEvent   String                                    // ticket_created, ticket_reminder, scan_failed, ticket_validated
  channel        String                                    // whatsapp, sms, email
  templateId     String?                                   // template identifier
  delayMinutes   Int      @default(0)                     // delay before sending
  fallbackChannel String?                                  // fallback if primary fails: sms, email
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@index([triggerEvent])
}

// ============================================================
// 📨 AUTOMATION LOGS (delivery tracking per automation rule)
// ============================================================
model AutomationLog {
  id             String   @id @default(cuid())
  organizationId String
  ruleId         String
  triggerEvent   String
  channel        String
  recipient      String                                    // phone/email
  status         String   @default("pending")              // pending, sent, failed, skipped
  errorMessage   String?
  attempts       Int      @default(0)
  createdAt      DateTime @default(now())
  sentAt         DateTime?

  @@index([organizationId])
  @@index([ruleId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// 🎫 SUPPORT TICKETS (customer support per organization)
// ============================================================
model SupportTicket {
  id             String    @id @default(cuid())
  organizationId String
  userId         String?
  subject        String
  message        String                                     // initial message
  priority       String    @default("medium")               // low, medium, high, critical
  status         String    @default("open")                 // open, in_progress, resolved, closed
  assignedTo     String?                                     // assigned user ID
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([userId])
  @@index([assignedTo])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// 🤝 AFFILIATES (referral tracking per organization)
// ============================================================
model Affiliate {
  id                   String   @id @default(cuid())
  organizationId       String
  userId               String
  code                 String   @unique                     // referral code
  commissionRate       Float    @default(5.0)              // percentage
  totalRevenueGenerated Float   @default(0)               // total commission-eligible revenue
  totalCommissionEarned  Float   @default(0)              // total paid out
  totalReferrals        Int     @default(0)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([code])
  @@index([userId])
  @@index([isActive])
}

// ============================================================
// 🚨 FRAUD ALERTS (detected suspicious activities)
// ============================================================
model FraudAlert {
  id             String   @id @default(cuid())
  organizationId String
  ticketId       String?
  userId         String?
  ruleType       String                                     // multi_scan_rapid, geo_inconsistent, suspicious_ip, device_mismatch
  severity       String   @default("medium")               // low, medium, high, critical
  details        String?                                    // JSON: { scans: [...], distances: [...], ip: "..." }
  status         String   @default("flagged")              // flagged, reviewed, dismissed, blocked
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, ruleType])
  @@index([severity])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// 🚌 TRANSPORT LINES (bus, boat, ferry, train routes)
// ============================================================
model TransportLine {
  id              String   @id @default(cuid())
  organizationId  String
  name            String                                  // "Bus 20 - Dakar vers Thiès"
  origin          String                                  // "Dakar"
  destination     String                                  // "Thiès"
  vehicleType     String   @default("bus")                // bus, boat, ferry, train
  color           String   @default("#059669")            // accent color for display
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  schedules       LineSchedule[]

  @@index([organizationId])
  @@index([organizationId, isActive])
}

// ============================================================
// 🕐 LINE SCHEDULES (departure & arrival times per line)
// ============================================================
model LineSchedule {
  id              String   @id @default(cuid())
  lineId          String
  type            String                                   // departure, arrival
  time            String                                   // "HH:MM" format, e.g. "08:00"
  status          String   @default("on_time")             // on_time, delayed, cancelled
  delayMinutes    Int      @default(0)                     // minutes of delay
  note            String?                                  // e.g. "Retard de 15 min"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  line            TransportLine @relation(fields: [lineId], references: [id], onDelete: Cascade)

  @@index([lineId])
  @@index([lineId, type])
  @@index([type])
  @@index([time])
}
