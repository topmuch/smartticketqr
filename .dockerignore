# =============================================================================
# SmartTicketQR — Docker Ignore File
# =============================================================================
# Excludes files and directories that should NOT be copied into the Docker
# build context. This reduces:
#   1. Image size       — unnecessary files bloat the build context
#   2. Build time       — smaller context = faster docker build
#   3. Security risk    — secrets and local data stay out of the image
# =============================================================================

# --- Dependencies (installed fresh during Docker build) ---
node_modules

# --- Next.js build output (rebuilt inside the container) ---
.next

# --- Version Control ---
.git
.gitignore
.gitattributes

# --- Environment Files (contain secrets — NEVER in the image) ---
.env
.env.local
.env.*.local

# --- Documentation (not needed at runtime) ---
*.md
docs/
LICENSE

# --- Local Database Files (use Docker volume mounts instead) ---
db/
*.db
*.db-journal
*.db-wal
*.db-shm

# --- IDE and Editor Configuration ---
.vscode
.idea
*.swp
*.swo
*~

# --- Operating System Files ---
.DS_Store
Thumbs.db
.Spotlight-V100
.Trashes

# --- Docker Files (don't nest Docker config inside itself) ---
Dockerfile
docker-compose.yml
docker-compose.*.yml
.dockerignore
Caddyfile

# --- CI/CD Configuration ---
.github/
.gitlab-ci.yml
.circleci/

# --- Download Artifacts ---
download/

# --- Agent / Development Context ---
agent-ctx/
worklog.md
examples/

# --- Mini Services (built independently if needed) ---
mini-services/

# --- Logs (don't carry local logs into the image) ---
*.log
logs/
dev.log
server.log

# --- Test Files ---
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# --- Backup Scripts ---
scripts/
backup/
